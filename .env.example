# ============================================================
# AI Voice Customer Support Agent — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── Application ──
APP_ENV=development
APP_NAME=VoiceAI
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-random-256-bit-key
DEBUG=true

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=voiceai
POSTGRES_USER=voiceai
POSTGRES_PASSWORD=changeme_pg_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ── JWT Auth ──
JWT_SECRET_KEY=change-me-jwt-secret-key-256-bits
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenAI ──
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Deepgram (STT) ──
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Cartesia (TTS) ──
CARTESIA_API_KEY=your-cartesia-api-key

# ── ElevenLabs (TTS Alternative) ──
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── LiveKit ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ── Twilio ──
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Pinecone (Vector DB) ──
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=knowledge-base

# ── Service URLs (internal) ──
AI_BRAIN_URL=http://ai-brain:8001
AUTH_SERVICE_URL=http://auth-service:8002
TICKET_SERVICE_URL=http://ticket-service:8003
ANALYTICS_SERVICE_URL=http://analytics-service:8004
NOTIFICATION_SERVICE_URL=http://notification-service:8005

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── S3 (Call Recordings) ──
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_RECORDINGS=voiceai-recordings
